# ─────────────────────────────────────────────────────────────────────────────
# Maison du Vin — environment variables
# Copy to `.env` and fill in. Only DATABASE_URL and JWT_SECRET are required for
# local dev; everything else defaults to a stub implementation.
# ─────────────────────────────────────────────────────────────────────────────

# Database — PostgreSQL (Supabase) ──────────────────────────────────────────────
# Supabase dashboard → Project Settings → Database → Connection string.
# DATABASE_URL: "Transaction pooler" tab — host "...pooler...", port 6543.
#   Used by the app at runtime (serverless-friendly). Keep the pgbouncer flags.
# DIRECT_URL:   "Direct connection" tab — port 5432. Used by `prisma migrate`.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Auth ─────────────────────────────────────────────────────────────────────────
# Secret used to sign JWT access/refresh tokens. Use a long random string.
JWT_SECRET="replace-with-a-long-random-string"

# App ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# External service selection ───────────────────────────────────────────────────
# "stub" (default) wires the code path without external credentials.
PAYMENTS_PROVIDER="stub"   # stub | stripe
EMAIL_PROVIDER="stub"      # stub | resend | sendgrid
STORAGE_PROVIDER="stub"    # stub | s3 | cloudinary

# Stripe (PAYMENTS_PROVIDER=stripe) ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email (EMAIL_PROVIDER=resend|sendgrid) ────────────────────────────────────────
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM="Maison du Vin <hello@maisonduvin.example>"

# Storage — AWS S3 (STORAGE_PROVIDER=s3) ────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# Storage — Cloudinary (STORAGE_PROVIDER=cloudinary) ────────────────────────────
CLOUDINARY_URL=

# Google OAuth ──────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase ──────────────────────────────────────────────────────────────────────
# Project URL and publishable (anon) key from the Supabase dashboard
# (Project Settings → API). Both are safe to expose to the browser and are
# required by src/lib/supabase/* and the session refresh in proxy.ts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
